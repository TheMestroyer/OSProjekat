  70:src/Scheduler.cpp **** KThread* Scheduler::GetNext() {
  71:src/Scheduler.cpp ****     for (int i = 0; i < LEVELS; i++) {
  72:src/Scheduler.cpp ****         if (readyHead[i] == nullptr) continue;
  73:src/Scheduler.cpp ****         KThread* toRet = readyHead[i];
  74:src/Scheduler.cpp ****         readyHead[i] = toRet->getNextInQueue();
  75:src/Scheduler.cpp ****         if (readyHead[i] != nullptr) readyHead[i]->setPrevInQueue(nullptr);
  76:src/Scheduler.cpp ****         else readyTail[i] = nullptr;
  77:src/Scheduler.cpp ****         toRet->setNextInQueue(nullptr);
  78:src/Scheduler.cpp ****         toRet->setPrevInQueue(nullptr);
  79:src/Scheduler.cpp ****         return toRet;
  80:src/Scheduler.cpp ****     }
  81:src/Scheduler.cpp ****     return nullptr;
  82:src/Scheduler.cpp **** }
  83:src/Scheduler.cpp **** 
  84:src/Scheduler.cpp **** void Scheduler::Put(KThread* thread) {
  85:src/Scheduler.cpp ****     int lvl = thread->priority;
  86:src/Scheduler.cpp ****     thread->setNextInQueue(nullptr);
  87:src/Scheduler.cpp ****     thread->setPrevInQueue(readyTail[lvl]);
  88:src/Scheduler.cpp ****     if (readyTail[lvl] != nullptr) readyTail[lvl]->setNextInQueue(thread);
  89:src/Scheduler.cpp ****     else readyHead[lvl] = thread;
  90:src/Scheduler.cpp ****     readyTail[lvl] = thread;
  91:src/Scheduler.cpp **** }
  92:src/Scheduler.cpp **** 
  93:src/Scheduler.cpp **** void Scheduler::PutPreempted(KThread* thread) {
  94:src/Scheduler.cpp ****     if (thread->priority < LEVELS - 1) thread->priority++;
  95:src/Scheduler.cpp ****     Put(thread);
  96:src/Scheduler.cpp **** }
