  61:src/Scheduler.cpp **** void Scheduler::Put(KThread* thread) {
  62:src/Scheduler.cpp ****     int lvl = thread->priority;
  63:src/Scheduler.cpp ****     thread->setNextInQueue(nullptr);
  64:src/Scheduler.cpp ****     thread->setPrevInQueue(readyTail[lvl]);
  65:src/Scheduler.cpp ****     if (readyTail[lvl] != nullptr) readyTail[lvl]->setNextInQueue(thread);
  66:src/Scheduler.cpp ****     else readyHead[lvl] = thread;
  67:src/Scheduler.cpp ****     readyTail[lvl] = thread;
  68:src/Scheduler.cpp **** }
