  69:src/Scheduler.cpp **** KThread* Scheduler::GetNext() {
  70:src/Scheduler.cpp ****     for (int i = 0; i < LEVELS; i++) {
  71:src/Scheduler.cpp ****         if (readyHead[i] == nullptr) continue;
  72:src/Scheduler.cpp ****         KThread* toRet = readyHead[i];
  73:src/Scheduler.cpp ****         readyHead[i] = toRet->getNextInQueue();
  74:src/Scheduler.cpp ****         if (readyHead[i] != nullptr) readyHead[i]->setPrevInQueue(nullptr);
  75:src/Scheduler.cpp ****         else readyTail[i] = nullptr;
  76:src/Scheduler.cpp ****         toRet->setNextInQueue(nullptr);
  77:src/Scheduler.cpp ****         toRet->setPrevInQueue(nullptr);
  78:src/Scheduler.cpp ****         return toRet;
  79:src/Scheduler.cpp ****     }
  80:src/Scheduler.cpp ****     return nullptr;
  81:src/Scheduler.cpp **** }
  82:src/Scheduler.cpp **** 
  83:src/Scheduler.cpp **** void Scheduler::Put(KThread* thread) {
  84:src/Scheduler.cpp ****     int lvl = thread->priority;
  85:src/Scheduler.cpp ****     thread->setNextInQueue(nullptr);
  86:src/Scheduler.cpp ****     thread->setPrevInQueue(readyTail[lvl]);
  87:src/Scheduler.cpp ****     if (readyTail[lvl] != nullptr) readyTail[lvl]->setNextInQueue(thread);
  88:src/Scheduler.cpp ****     else readyHead[lvl] = thread;
  89:src/Scheduler.cpp ****     readyTail[lvl] = thread;
  90:src/Scheduler.cpp **** }
  91:src/Scheduler.cpp **** 
  92:src/Scheduler.cpp **** void Scheduler::PutPreempted(KThread* thread) {
  93:src/Scheduler.cpp ****     if (thread->priority < LEVELS - 1) thread->priority++;
  94:src/Scheduler.cpp ****     Put(thread);
  95:src/Scheduler.cpp **** }
