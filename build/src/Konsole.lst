  22:src/Konsole.cpp **** void Konsole::enqueueGetcWaiter(KThread* thread) {
  23:src/Konsole.cpp ****     thread->setNextInQueue(nullptr);
  24:src/Konsole.cpp ****     if (getcWaiterTail != nullptr) {
  25:src/Konsole.cpp ****         thread->setPrevInQueue(getcWaiterTail);
  26:src/Konsole.cpp ****         getcWaiterTail->setNextInQueue(thread);
  27:src/Konsole.cpp ****     } else {
  28:src/Konsole.cpp ****         thread->setPrevInQueue(nullptr);
  29:src/Konsole.cpp ****         getcWaiterHead = thread;
  30:src/Konsole.cpp ****     }
  31:src/Konsole.cpp ****     getcWaiterTail = thread;
  32:src/Konsole.cpp **** }
  33:src/Konsole.cpp **** 
  34:src/Konsole.cpp **** KThread* Konsole::dequeueGetcWaiter() {
  35:src/Konsole.cpp ****     if (getcWaiterHead == nullptr) return nullptr;
  36:src/Konsole.cpp ****     KThread* thread = getcWaiterHead;
  37:src/Konsole.cpp ****     getcWaiterHead = thread->getNextInQueue();
  38:src/Konsole.cpp ****     if (getcWaiterHead != nullptr) getcWaiterHead->setPrevInQueue(nullptr);
  39:src/Konsole.cpp ****     else getcWaiterTail = nullptr;
  40:src/Konsole.cpp ****     thread->setNextInQueue(nullptr);
  41:src/Konsole.cpp ****     thread->setPrevInQueue(nullptr);
  42:src/Konsole.cpp ****     return thread;
  43:src/Konsole.cpp **** }
